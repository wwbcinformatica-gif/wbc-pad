{
  "appId": "com.wbc.notepad",
  "appName": "WBC NotePad",
  "webDir": "out",
  "server": {
    "url": "https://wbc-notepad.vercel.app",
    "cleartext": false
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#f5f7fa",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    },
    "Haptics": {
      "notificationFeedback": true
    }
  }
}
