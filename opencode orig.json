{
  "$schema": "https://opencode.ai/config.json",
  "model": "ollama/qwen2.5-coder:7b",
  "provider": {
    "google": {
      "npm": "@ai-sdk/google",
      "options": {
        "apiKey": "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"
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "deepseek-r1:7b": {
          "name": "DeepSeek R1 7B (4.7 GB)"
        },
        "deepseek-r1:14b": {
          "name": "DeepSeek R1 14B (9.0 GB)"
        },
        "deepseek-coder-v2:latest": {
          "name": "DeepSeek Coder V2 Latest (8.9 GB)"
        },
        "deepseek-coder:6.7b": {
          "name": "DeepSeek Coder 6.7B (3.8 GB)"
        },
        "qwen2.5-coder:7b": {
          "name": "Qwen 2.5 Coder 7B (4.7 GB)"
        },
        "michaelbui/nemomix-unleashed-12b:q4-k-m": {
          "name": "Nemomix Unleashed 12B Q4 (7.5 GB)"
        }
      }
    },
    "agent": {
      "claude": {
        "description": "Claude Sonnet - Agente completo com todas as ferramentas",
        "mode": "primary",
        "model": "anthropic/claude-3.5-sonnet",
        "permission": {
          "edit": "allow",
          "read": "allow",
          "bash": "allow"
        }
      },
      "ollama-local": {
        "description": "Agente otimizado para modelos Ollama locais - sem ferramentas externas",
        "mode": "primary",
        "model": "ollama/qwen2.5-coder:7b",
        "permission": {
          "edit": "allow",
          "read": "allow",
          "bash": "allow",
          "webfetch": "allow",
          "task": "allow",
          "skill": "allow",
          "question": "allow"
        }
      },
      "default": {
        "systemPromptFile": ".agent/agents/gemini.md"
      }
    }
  }
}